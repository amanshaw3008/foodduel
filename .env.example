# ── App ──────────────────────────────────────────
APP_ENV=development
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=900

# ── Google Places (use now as fallback) ───────────
GOOGLE_PLACES_API_KEY=your_google_places_key_here
USE_MOCK_PROVIDERS=true

# ── Swiggy (fill after API access approved) ───────
SWIGGY_API_KEY=
SWIGGY_BASE_URL=https://api.swiggy.com/v1

# ── Zomato (fill after API access approved) ───────
ZOMATO_API_KEY=
ZOMATO_BASE_URL=https://developers.zomato.com/api/v2.1
